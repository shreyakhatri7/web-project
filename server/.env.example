# Railway.app Database Configuration
# Replace these values with your Railway.app MySQL database credentials

# Local Development (comment out when using Railway)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=shreya123
# DB_NAME=internship_portal
# DB_SSL=false

# Railway.app Production Database
# Get these values from your Railway.app MySQL database settings
DB_HOST=your-railway-db-host.railway.app
DB_PORT=your-db-port
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_NAME=railway
DB_SSL=true

# JWT Secret Key
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=8000

# Database setup mode for `npm run setup:db`
# false = preserve existing data, true = drop and recreate tables
RESET_DB=false

# ==========================================
# Admin Seeding (manual DB-created admin)
# Run: npm run seed:admin
# ==========================================
ADMIN_EMAIL=admin@jobportal.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=
ADMIN_PERMISSIONS=manage_users,manage_jobs,manage_employers,view_reports